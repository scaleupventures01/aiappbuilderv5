{
  "name": "team-leader-system",
  "version": "4.0.0",
  "description": "Hierarchical AI Agent Orchestration System",
  "main": "start.js",
  "scripts": {
    "start": "node start.js",
    "test": "node tests/test-complete-system.js",
    "setup": "node setup.js",
    "quick-test": "node tests/quick-test.js",
    "browser": "open index.html",
    "test:initiation": "node tests/test-project-initiation.js",
    "test:refactoring": "node tests/test-complete-refactoring.js",
    "test:dashboard": "node tests/test-dashboard-refactoring.js",
    "docker:build": "docker build -t team-leader-system .",
    "docker:run": "docker run -p 3000:3000 team-leader-system",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "pre-commit": "./scripts/pre-commit.sh",
    "setup:env": "cp config/env.example .env && echo 'Environment file created. Please edit .env with your API keys.'",
    "check:providers": "node scripts/check-providers.js"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "team-leader",
    "hierarchical",
    "management",
    "automation"
  ],
  "author": "Team Leader System",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/team-leader-system/v4.0"
  },
  "bugs": {
    "url": "https://github.com/team-leader-system/v4.0/issues"
  },
  "homepage": "https://github.com/team-leader-system/v4.0#readme",
  "dependencies": {
    "dotenv": "^17.2.1"
  },
  "optionalDependencies": {
    "node-fetch": "^3.3.2"
  }
}
