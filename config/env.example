# Team Leader System v4.0 - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM API KEYS (Optional but recommended for best performance)
# =============================================================================

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google API Key (for Gemini models)
GOOGLE_API_KEY=your_google_api_key_here

# DeepSeek API Key (for DeepSeek models)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================

# Environment (development, staging, production)
NODE_ENV=development

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Dashboard Port (for local development)
DASHBOARD_PORT=3000

# Auto-update Interval (milliseconds)
AUTO_UPDATE_INTERVAL=5000

# =============================================================================
# COST MANAGEMENT
# =============================================================================

# Monthly Budget Limit (USD)
MONTHLY_BUDGET_LIMIT=100

# Cost Alert Threshold (percentage of budget)
COST_ALERT_THRESHOLD=80

# Enable Cost Tracking (true/false)
ENABLE_COST_TRACKING=true

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Default Model Provider (openai, anthropic, google, deepseek)
DEFAULT_MODEL_PROVIDER=openai

# Enable Model Fallbacks (true/false)
ENABLE_MODEL_FALLBACKS=true

# Model Selection Strategy (cost, performance, balanced)
MODEL_SELECTION_STRATEGY=balanced

# =============================================================================
# PROJECT SETTINGS
# =============================================================================

# Default Project Template (webapp, mobile, ecommerce, saas, website)
DEFAULT_PROJECT_TEMPLATE=webapp

# Auto-approve Simple Tasks (true/false)
AUTO_APPROVE_SIMPLE_TASKS=false

# Enable Real-time Dashboard (true/false)
ENABLE_REAL_TIME_DASHBOARD=true

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Enable API Key Validation (true/false)
ENABLE_API_KEY_VALIDATION=true

# Require User Approval for Costly Operations (true/false)
REQUIRE_APPROVAL_FOR_COSTLY_OPERATIONS=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable Debug Mode (true/false)
DEBUG_MODE=false

# Enable Detailed Logging (true/false)
DETAILED_LOGGING=false

# Test Mode (true/false) - Uses mock responses
TEST_MODE=false

# =============================================================================
# INTEGRATION SETTINGS
# =============================================================================

# MCP Server URL (for multi-model support)
MCP_SERVER_URL=http://localhost:4000

# Enable MCP Integration (true/false)
ENABLE_MCP_INTEGRATION=false

# Webhook URL (for external notifications)
WEBHOOK_URL=

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Max Concurrent Requests
MAX_CONCURRENT_REQUESTS=5

# Request Timeout (milliseconds)
REQUEST_TIMEOUT=30000

# Enable Response Caching (true/false)
ENABLE_RESPONSE_CACHING=true

# Cache TTL (seconds)
CACHE_TTL=3600

# =============================================================================
# MONITORING SETTINGS
# =============================================================================

# Enable Health Monitoring (true/false)
ENABLE_HEALTH_MONITORING=true

# Health Check Interval (milliseconds)
HEALTH_CHECK_INTERVAL=60000

# Enable Performance Metrics (true/false)
ENABLE_PERFORMANCE_METRICS=true

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================

# Enable Email Notifications (true/false)
ENABLE_EMAIL_NOTIFICATIONS=false

# SMTP Configuration (if email notifications enabled)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Slack Webhook URL (for Slack notifications)
SLACK_WEBHOOK_URL=

# =============================================================================
# BACKUP AND RECOVERY
# =============================================================================

# Enable Auto Backup (true/false)
ENABLE_AUTO_BACKUP=true

# Backup Interval (hours)
BACKUP_INTERVAL=24

# Backup Retention (days)
BACKUP_RETENTION=7

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

# Custom Model Configurations (JSON string)
CUSTOM_MODEL_CONFIG={}

# Custom Agent Prompts (JSON string)
CUSTOM_AGENT_PROMPTS={}

# System Override Settings (JSON string)
SYSTEM_OVERRIDE_SETTINGS={} 